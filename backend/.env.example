# ============================================
# CORTEX PLATFORM v2.1 — Environment Variables
# ============================================

# Server Configuration
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_PATH=./data/cortex.db

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this

# Paystack Configuration
# LIVE Keys
PAYSTACK_MODE=live
PAYSTACK_PUBLIC_KEY=pk_live_d7f59d46d24abebfb35ae3ae5b397f8ba4e919fc
PAYSTACK_SECRET_KEY=sk_live_your_actual_secret_key_here

# TEST Keys (for development)
# PAYSTACK_MODE=test
# PAYSTACK_PUBLIC_KEY=pk_test_cfeb04b79e16c6c813c17f654766bfd09c7ece0f
# PAYSTACK_SECRET_KEY=sk_test_your_test_secret_key_here

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@cortex-platform.com

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/cortex.log
