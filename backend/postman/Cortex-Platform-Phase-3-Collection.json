        {
          "name": "Email Logs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/emails/logs?limit=20&status=sent",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "api",
                "emails",
                "logs"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "status",
                  "value": "sent",
                  "description": "Filter: sent, pending, failed"
                }
              ]
            },
            "description": "View email sending history and status"
          }
        }
      ]
    },
    {
