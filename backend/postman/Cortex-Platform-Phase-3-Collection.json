            "url": {
              "raw": "{{BASE_URL}}/api/emails/receipt",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "api",
                "emails",
                "receipt"
              ]
            },
            "description": "Manually send payment receipt email (usually sent automatically)"
          }
        },
        {
          "name": "Send Order Confirmation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
