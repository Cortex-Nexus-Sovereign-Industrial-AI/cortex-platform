# ============================================
# CORTEX PLATFORM — Environment Configuration
# CINIS NEXUS INDUSTRY OGOJA
# ============================================
# NEVER commit this file with real values.
# Copy to .env and fill in your secrets.
# .env is in .gitignore — keep it that way.

# --------------------------------------------
# PAYSTACK (Primary Payment Gateway)
# --------------------------------------------
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here
PAYSTACK_WEBHOOK_SECRET=whsec_your_paystack_webhook_secret_here
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here

# --------------------------------------------
# FLUTTERWAVE (Secondary/Cross-border)
# --------------------------------------------
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_flutterwave_secret_key_here
FLUTTERWAVE_WEBHOOK_SECRET=your_flutterwave_webhook_secret_here
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your_flutterwave_public_key_here

# --------------------------------------------
# SHOPIFY (E-commerce Integration)
# --------------------------------------------
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here
SHOPIFY_STORE_URL=yourstore.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token_here

# --------------------------------------------
# GOOGLE CLOUD (Infrastructure)
# --------------------------------------------
GOOGLE_CLOUD_PROJECT_ID=your_gcp_project_id
GOOGLE_CLOUD_API_KEY=your_gcp_api_key
GOOGLE_CLOUD_SERVICE_ACCOUNT=path/to/service-account.json

# --------------------------------------------
# PLATFORM
# --------------------------------------------
FLASK_APP=webhook_trigger_engine.py
FLASK_DEBUG=false
PORT=8080
SECRET_KEY=your_random_secret_key_for_sessions_here

# --------------------------------------------
# EMAIL (ProtonMail / SMTP)
# --------------------------------------------
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=cortexnexus@proton.me
SMTP_PASSWORD=your_email_password_here
