# 1. Initialize repository
git init

# 2. Add the Cortex build file
git add CORTEX_BUILD.json

# 3. Commit with signed verification
git commit -S -m "Commit: Autonomous Cortex Build CNIO-2026-CORTEX-02"

# 4. Link to GitHub remote
git remote add origin https://github.com/YourOrg/CortexPlatform.git

# 5. Push to staging branch first
git push origin staging

# 6. Merge into main after validation
git checkout main
git merge staging
git push origin main
