# Server Config
NODE_ENV=production
PORT=5000
DATABASE_URL=sqlite:./social_media.db
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Twitter/X API
TWITTER_BEARER_TOKEN=your_bearer_token_here
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_SECRET=your_access_secret_here

# LinkedIn
LINKEDIN_ACCESS_TOKEN=your_access_token_here
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# TikTok
TIKTOK_APP_ID=your_app_id_here
TIKTOK_APP_SECRET=your_app_secret_here
TIKTOK_ACCESS_TOKEN=your_access_token_here

# Instagram
INSTAGRAM_GRAPH_TOKEN=your_graph_token_here
INSTAGRAM_PAGE_ID=your_page_id_here

# YouTube
YOUTUBE_API_KEY=your_api_key_here
YOUTUBE_CHANNEL_ID=your_channel_id_here

# Medium
MEDIUM_INTEGRATION_TOKEN=your_integration_token_here
MEDIUM_USER_ID=your_user_id_here

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# WhatsApp Business
WHATSAPP_BUSINESS_TOKEN=your_business_token_here
WHATSAPP_PHONE_ID=your_phone_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here

# File Upload
MAX_FILE_SIZE=104857600
ALLOWED_MIME_TYPES=image/jpeg,image/png,video/mp4,video/quicktime

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log
