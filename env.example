# Cortex Platform runtime env — example only (DO NOT commit real secrets)
# Copy this file to .env and fill local values. Add .env to .gitignore.

# Paystack (required for region)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

# Shopify placeholders (for CI / integration)
SHOPIFY_API_KEY=your_shopify_api_key_placeholder
SHOPIFY_API_SECRET=your_shopify_api_secret_placeholder
SHOPIFY_SHOP_CUSTOM_DOMAIN=your_store_name.myshopify.com

# Optional / Shopify sync (CI usage)
SHOPIFY_APP_TOKEN=your_shopify_app_token_here
SHOPIFY_STORE_DOMAIN=your-shop.myshopify.com
THEME_ID=your_theme_id_or_empty

# Webhook runtime
PORT=8080
HOST=0.0.0.0

# Optional (if you enable stripe later)
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_API_KEY=sk_xxx

# Optional runtime flags
# LOG_LEVEL=INFO
# PROCESSED_STORE=processed_events.json
